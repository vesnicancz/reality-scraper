<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="color-scheme" content="light">
	<meta name="supported-color-schemes" content="light">
	<title>Notifikace změn na realitních serverech</title>
	<style>
		/* SHARED EMAIL STYLES — keep in sync with RemovedListingsReport.cshtml */
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		:root {
			color-scheme: light;
		}

		body {
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
			line-height: 1.5;
			color: #1f2937;
			max-width: 640px;
			margin: 0 auto;
			padding: 20px;
			background-color: #f1f2f4;
		}

		.header {
			text-align: center;
			margin-bottom: 24px;
		}

		.header .eyebrow {
			color: #6b7280;
			font-size: 12px;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 2px;
			margin-bottom: 4px;
		}

		.header h1 {
			font-size: 24px;
			font-weight: 700;
			margin-bottom: 6px;
		}

		.header p {
			color: #6b7280;
			font-size: 15px;
		}

		.summary {
			background-color: #ffffff;
			color: #1f2937;
			padding: 16px;
			margin-bottom: 24px;
			border: 1px solid #e5e7eb;
			border-radius: 10px;
		}

		.portal-section {
			background-color: #ffffff;
			margin-bottom: 24px;
			border: 1px solid #e5e7eb;
			border-radius: 10px;
			overflow: hidden;
		}

		.portal-header {
			width: 100%;
			border-collapse: collapse;
		}

		.portal-header td {
			padding: 14px 16px;
		}

		.portal-header h2 {
			color: #ffffff;
			font-size: 18px;
			font-weight: 600;
		}

		.portal-header .count {
			background-color: #ffffff;
			font-size: 14px;
			font-weight: 600;
			border-radius: 16px;
			padding: 2px 10px;
		}

		.section-header {
			width: 100%;
			border-collapse: collapse;
			background-color: #f3f4f6;
		}

		.section-header td {
			padding: 12px 16px;
			border-bottom: 1px solid #e5e7eb;
		}

		.section-header .label {
			font-weight: 600;
			font-size: 15px;
			color: #1f2937;
		}

		.section-header .count {
			color: #ffffff;
			font-size: 13px;
			font-weight: 600;
			border-radius: 16px;
			padding: 2px 10px;
		}

		.property-list {
			padding: 0;
			margin: 0;
			list-style: none;
		}

		.property-item {
			padding: 16px;
			border-bottom: 1px solid #e5e7eb;
		}

		.property-item:last-child {
			border-bottom: none;
		}

		.property-row {
			width: 100%;
			border-collapse: collapse;
		}

		.property-image-cell {
			padding-right: 16px;
		}

		.property-image {
			width: 120px;
			height: 90px;
			object-fit: cover;
			border-radius: 8px;
			display: block;
			background-color: #e5e7eb;
		}

		.property-image-placeholder {
			width: 120px;
			height: 90px;
			border-radius: 8px;
			background-color: #e5e7eb;
			color: #9ca3af;
			font-size: 30px;
			text-align: center;
			line-height: 90px;
		}

		.property-title {
			font-weight: 600;
			font-size: 16px;
			color: #1f2937;
			margin-bottom: 2px;
		}

		.property-location {
			color: #6b7280;
			font-size: 13px;
			margin-bottom: 6px;
		}

		.property-price {
			font-weight: 700;
			font-size: 18px;
			margin-bottom: 6px;
		}

		.property-old-price {
			color: #9ca3af;
			font-size: 13px;
			margin-bottom: 6px;
		}

		.property-meta {
			color: #6b7280;
			font-size: 13px;
			margin-bottom: 10px;
		}

		.property-link {
			display: inline-block;
			color: #ffffff !important;
			text-decoration: none;
			padding: 8px 16px;
			border-radius: 8px;
			font-weight: 500;
			font-size: 14px;
		}

		.footer {
			text-align: center;
			color: #6b7280;
			font-size: 13px;
			margin-top: 8px;
		}

		@@media only screen and (max-width: 480px) {
			body {
				padding: 12px;
			}

			.header h1 {
				font-size: 21px;
			}

			.property-item {
				padding: 12px;
			}
		}
		/* END SHARED EMAIL STYLES */

		/* ACCENT & REPORT-SPECIFIC STYLES (blue) */
		.header h1 {
			color: #2563eb;
		}

		.summary {
			border-left: 4px solid #3b82f6;
		}

		.portal-header {
			background-color: #2563eb;
		}

		.portal-header .count {
			color: #2563eb;
		}

		.section-header .count {
			background-color: #2563eb;
		}

		.property-price {
			color: #2563eb;
		}

		.property-link {
			background-color: #2563eb;
		}

		.price-change {
			font-size: 13px;
			font-weight: 600;
			padding: 2px 8px;
			border-radius: 10px;
			margin-left: 6px;
		}

		.price-down {
			background-color: #d1fae5;
			color: #065f46;
		}

		.price-up {
			background-color: #fef3c7;
			color: #92400e;
		}
	</style>
</head>
<body>
	<div class="header">
		<p class="eyebrow">Realitní monitoring</p>
		<h1>Notifikace realitních nabídek</h1>
		@if (!string.IsNullOrWhiteSpace(Model.TaskName))
		{
			<p><strong>@E(Model.TaskName)</strong></p>
		}
		<p>Přehled změn ze dne @Model.ReportDate.ToString("dd.MM.yyyy HH:mm")</p>
	</div>

	<div class="summary">
		<p>Souhrn změn: @GetPluralForm(Model.NewListingsCount, "nalezena", "nalezeny", "nalezeno")
			<strong>@GetPluralFormWithNumber(Model.NewListingsCount, "nová nabídka", "nové nabídky", "nových nabídek")</strong>
			a <strong>@GetPluralFormWithNumber(@Model.PriceChangedListingsCount, "změna ceny", "změny ceny", "změn cen")</strong>
			napříč sledovanými portály.
		</p>
	</div>

	@foreach (var result in Model.GetNotEmptyResults())
	{
		<div class="portal-section">
			<table role="presentation" class="portal-header" width="100%" cellpadding="0" cellspacing="0">
				<tr>
					<td><h2>@result.SiteName</h2></td>
					<td align="right"><span class="count">@result.TotalListingsCount</span></td>
				</tr>
			</table>

			@if (result.NewListingsCount > 0)
			{
				<!-- Nové nabídky -->
				<table role="presentation" class="section-header" width="100%" cellpadding="0" cellspacing="0">
					<tr>
						<td class="label">Nové nabídky</td>
						<td align="right"><span class="count">@result.NewListingsCount</span></td>
					</tr>
				</table>
				<ul class="property-list">

					@foreach (var listing in result.NewListings)
					{
						<li class="property-item">
							<table role="presentation" class="property-row" width="100%" cellpadding="0" cellspacing="0">
								<tr>
									<td class="property-image-cell" width="136" valign="top">
										@if (!string.IsNullOrEmpty(listing.ImageUrl))
										{
											<img src="@SafeUrl(listing.ImageUrl)" alt="@E(listing.Location)" class="property-image">
										}
										else
										{
											<div class="property-image-placeholder">&#127968;</div>
										}
									</td>
									<td valign="top">
										<div class="property-title">@E(string.IsNullOrWhiteSpace(listing.Title) ? listing.Location : listing.Title)</div>
										@if (!string.IsNullOrWhiteSpace(listing.Title) && !string.IsNullOrWhiteSpace(listing.Location))
										{
											<div class="property-location">&#128205; @E(listing.Location)</div>
										}
										<div class="property-price">@FormatPrice(listing.Price)</div>
										<a href="@SafeUrl(listing.Url)" class="property-link">Zobrazit detail</a>
									</td>
								</tr>
							</table>
						</li>
					}
				</ul>
			}

			@if (result.PriceChangedListingsCount > 0)
			{
				<!-- Změny cen -->
				<table role="presentation" class="section-header" width="100%" cellpadding="0" cellspacing="0">
					<tr>
						<td class="label">Změny cen</td>
						<td align="right"><span class="count">@result.PriceChangedListingsCount</span></td>
					</tr>
				</table>
				<ul class="property-list">

					@foreach (var listing in result.PriceChangedListings)
					{
						<li class="property-item">
							<table role="presentation" class="property-row" width="100%" cellpadding="0" cellspacing="0">
								<tr>
									<td class="property-image-cell" width="136" valign="top">
										@if (!string.IsNullOrEmpty(listing.ImageUrl))
										{
											<img src="@SafeUrl(listing.ImageUrl)" alt="@E(listing.Location)" class="property-image">
										}
										else
										{
											<div class="property-image-placeholder">&#127968;</div>
										}
									</td>
									<td valign="top">
										<div class="property-title">@E(string.IsNullOrWhiteSpace(listing.Title) ? listing.Location : listing.Title)</div>
										@if (!string.IsNullOrWhiteSpace(listing.Title) && !string.IsNullOrWhiteSpace(listing.Location))
										{
											<div class="property-location">&#128205; @E(listing.Location)</div>
										}
										<div class="property-price">
											@FormatPrice(listing.Price)
											@if (listing.PriceDiff < 0)
											{
												<span class="price-change price-down">&#8595; @FormatPrice(listing.PriceDiff)@FormatPercent(listing.PriceDiff, listing.OldPrice)</span>
											}
											else if (listing.PriceDiff > 0)
											{
												<span class="price-change price-up">&#8593; +@FormatPrice(listing.PriceDiff)@FormatPercent(listing.PriceDiff, listing.OldPrice)</span>
											}
										</div>
										<div class="property-old-price"><s>původně @FormatPrice(listing.OldPrice)</s></div>
										<a href="@SafeUrl(listing.Url)" class="property-link">Zobrazit detail</a>
									</td>
								</tr>
							</table>
						</li>
					}
				</ul>
			}
		</div>
	}

	<div class="footer">
		<p>Toto je automaticky generovaná zpráva z vašeho realitního monitoringu.</p>
	</div>
</body>
</html>

@{
	string GetPluralForm(int count, string form1, string form2to4, string form5plus)
	{
		if (count == 1)
		{
			return form1;
		}
		else if (count >= 2 && count <= 4)
		{
			return form2to4;
		}
		else
		{
			return form5plus;
		}
	}

	string GetPluralFormWithNumber(int count, string form1, string form2to4, string form5plus)
	{
		if (count == 1)
		{
			return $"{count} {form1}";
		}
		else if (count >= 2 && count <= 4)
		{
			return $"{count} {form2to4}";
		}
		else
		{
			return $"{count} {form5plus}";
		}
	}

	string FormatPrice(decimal? price)
	{
		if (price.HasValue)
		{
			return price.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ"));
		}
		else
		{
			return "neuvedeno";
		}
	}

	string FormatPercent(decimal? diff, decimal? oldPrice)
	{
		if (diff.HasValue && oldPrice.HasValue && oldPrice.Value != 0)
		{
			var percent = System.Math.Round(diff.Value / oldPrice.Value * 100, 1);
			return $" ({percent.ToString("+0.#;-0.#", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ"))} %)";
		}
		else
		{
			return string.Empty;
		}
	}

	// RazorEngineCore na rozdíl od ASP.NET Razoru výrazy neenkóduje - scrapovaná data
	// (titulek, lokalita, URL) je nutné enkódovat ručně.
	string E(string value)
	{
		return System.Net.WebUtility.HtmlEncode(value ?? string.Empty);
	}

	string SafeUrl(string value)
	{
		if (!string.IsNullOrEmpty(value)
			&& (value.StartsWith("http://", System.StringComparison.OrdinalIgnoreCase)
				|| value.StartsWith("https://", System.StringComparison.OrdinalIgnoreCase)))
		{
			return System.Net.WebUtility.HtmlEncode(value);
		}

		return "#";
	}
}
