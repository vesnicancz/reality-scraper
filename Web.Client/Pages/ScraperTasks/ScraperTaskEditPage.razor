@attribute [AllowAnonymous]
@page "/scraper-tasks/create"
@page "/scraper-tasks/{Id:guid}/edit"
<PageTitle>@(IsEdit ? "Upravit task" : "Nový task")</PageTitle>

<h3>@(IsEdit ? "Upravit task" : "Nový task")</h3>

@if (isLoading)
{
    <HxSpinner />
}
else
{
    <EditForm Model="model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="row">
            <div class="col-md-6">
                <HxInputText @bind-Value="model.Name" Label="Název" />
            </div>
            <div class="col-md-4">
                <HxInputText @bind-Value="model.CronExpression" Label="Cron výraz" Hint="Např. 0 8 * * 1 (každé pondělí v 8:00)" />
            </div>
            <div class="col-md-2">
                <HxCheckbox @bind-Value="model.Enabled" Label="Aktivní" />
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <h5>Příjemci</h5>
                @for (var i = 0; i < model.Recipients.Count; i++)
                {
                    var index = i;
                    <div class="d-flex gap-2 mb-2 align-items-end">
                        <HxInputText @bind-Value="model.Recipients[index].Email" Label="@(index == 0 ? "Email" : null)" CssClass="flex-grow-1" />
                        <HxButton Color="ThemeColor.Danger" Icon="BootstrapIcon.Trash" Size="ButtonSize.Small" OnClick="() => RemoveRecipient(index)" />
                    </div>
                }
                <HxButton Text="Přidat příjemce" Color="ThemeColor.Secondary" Size="ButtonSize.Small" Icon="BootstrapIcon.PlusLg" OnClick="AddRecipient" />
            </div>
            <div class="col-md-6">
                <h5>Cíle scraperů</h5>
                @for (var i = 0; i < model.Targets.Count; i++)
                {
                    var index = i;
                    <div class="d-flex gap-2 mb-2 align-items-end">
                        <HxSelect TItem="ScraperTypeOption" TValue="int"
                                  @bind-Value="model.Targets[index].ScraperType"
                                  Label="@(index == 0 ? "Typ" : null)"
                                  Data="scraperTypeOptions"
                                  TextSelector="o => o.Name"
                                  ValueSelector="o => o.Value"
                                  CssClass="flex-shrink-0" style="min-width: 200px;"
                                  NullText=""
                                  NullDataText=""
                                  Nullable="false" />
                        <HxInputText @bind-Value="model.Targets[index].Url" Label="@(index == 0 ? "URL" : null)" CssClass="flex-grow-1" />
                        <HxButton Color="ThemeColor.Danger" Icon="BootstrapIcon.Trash" Size="ButtonSize.Small" OnClick="() => RemoveTarget(index)" />
                    </div>
                }
                <HxButton Text="Přidat cíl" Color="ThemeColor.Secondary" Size="ButtonSize.Small" Icon="BootstrapIcon.PlusLg" OnClick="AddTarget" />
            </div>
        </div>

        <div class="mt-4">
            <HxSubmit Text="@(IsEdit ? "Uložit" : "Vytvořit")" Color="ThemeColor.Primary" />
            <HxButton Text="Zpět" Color="ThemeColor.Secondary" Outline="true" OnClick="HandleCancel" />
        </div>
    </EditForm>
}